<?xml version="1.0" encoding="utf-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="20260507190000-1-create-entidad-financiera" author="codex">
        <createTable tableName="entidad_financiera">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="codigo" type="VARCHAR(30)">
                <constraints nullable="false" unique="true" uniqueConstraintName="uk_entidad_financiera_codigo"/>
            </column>
            <column name="nombre" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>
            <column name="descripcion" type="VARCHAR(255)"/>
            <column name="activa" type="BIT(1)" defaultValueBoolean="true">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

    <changeSet id="20260507190000-2-seed-entidad-financiera" author="codex">
        <sql>
            INSERT INTO entidad_financiera (codigo, nombre, descripcion, activa)
            VALUES
            ('BNA', 'Banco Nacion Argentina', 'Banco Nacion Argentina', b'1'),
            ('BBVA', 'BBVA Argentina', 'Banco BBVA', b'1'),
            ('SANTANDER', 'Banco Santander', 'Banco Santander', b'1'),
            ('GALICIA', 'Banco Galicia', 'Banco Galicia', b'1'),
            ('MACRO', 'Banco Macro', 'Banco Macro', b'1'),
            ('SUPERVIELLE', 'Banco Supervielle', 'Banco Supervielle', b'1'),
            ('MERCADOPAGO', 'Mercado Pago', 'Cuenta recaudadora Mercado Pago', b'1'),
            ('PAYPAL', 'PayPal', 'Cuenta recaudadora PayPal', b'1');
        </sql>
    </changeSet>

    <changeSet id="20260507190000-3-add-pago-fk" author="codex">
        <addColumn tableName="pago">
            <column name="entidad_financiera_id" type="BIGINT"/>
        </addColumn>
        <createIndex tableName="pago" indexName="idx_pago_entidad_financiera">
            <column name="entidad_financiera_id"/>
        </createIndex>
        <addForeignKeyConstraint
            baseTableName="pago"
            baseColumnNames="entidad_financiera_id"
            constraintName="fk_pago_entidad_financiera"
            referencedTableName="entidad_financiera"
            referencedColumnNames="id"/>
    </changeSet>

</databaseChangeLog>
