<?xml version="1.0" encoding="utf-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="20260418104000-1" author="codex">
        <preConditions onFail="MARK_RAN">
            <not>
                <columnExists tableName="comprobante" columnName="estado"/>
            </not>
        </preConditions>
        <addColumn tableName="comprobante">
            <column name="estado" type="varchar(20)" defaultValue="EMITIDO">
                <constraints nullable="false"/>
            </column>
            <column name="created_by" type="varchar(50)"/>
            <column name="last_modified_date" type="${datetimeType}"/>
            <column name="last_modified_by" type="varchar(50)"/>
        </addColumn>

        <update tableName="comprobante">
            <column name="estado" value="EMITIDO"/>
            <where>estado IS NULL</where>
        </update>

        <update tableName="comprobante">
            <column name="created_by" value="system"/>
            <where>created_by IS NULL</where>
        </update>

        <update tableName="comprobante">
            <column name="last_modified_date" valueComputed="CURRENT_TIMESTAMP"/>
            <where>last_modified_date IS NULL</where>
        </update>

        <update tableName="comprobante">
            <column name="last_modified_by" value="system"/>
            <where>last_modified_by IS NULL</where>
        </update>
    </changeSet>
</databaseChangeLog>
