<?xml version="1.0" encoding="utf-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="20260420170500-01-default-inventario-disponible" author="codex">
        <preConditions onFail="MARK_RAN">
            <and>
                <tableExists tableName="inventario"/>
                <columnExists tableName="inventario" columnName="disponible"/>
            </and>
        </preConditions>
        <addDefaultValue tableName="inventario" columnName="disponible" defaultValueBoolean="true"/>
    </changeSet>

    <changeSet id="20260420170500-02-backfill-inventario-disponible-null" author="codex">
        <preConditions onFail="MARK_RAN">
            <and>
                <tableExists tableName="inventario"/>
                <columnExists tableName="inventario" columnName="disponible"/>
            </and>
        </preConditions>
        <sql dbms="mysql">UPDATE inventario SET disponible = 1 WHERE disponible IS NULL;</sql>
    </changeSet>

</databaseChangeLog>
