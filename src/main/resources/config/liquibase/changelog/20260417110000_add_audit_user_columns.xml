    <changeSet id="20260417110000-5-cotizacion-audit-fields" author="codex">
        <preConditions onFail="MARK_RAN">
            <and>
                <tableExists tableName="cotizacion"/>
                <not>
                    <columnExists tableName="cotizacion" columnName="created_date"/>
                </not>
            </and>
        </preConditions>
        <addColumn tableName="cotizacion">
            <column name="created_date" type="${datetimeType}"/>
            <column name="last_modified_date" type="${datetimeType}"/>
            <column name="created_by" type="varchar(50)"/>
            <column name="last_modified_by" type="varchar(50)"/>
        </addColumn>
    </changeSet>
</databaseChangeLog>
