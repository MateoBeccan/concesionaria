<?xml version="1.0" encoding="utf-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="20260419143000-01-drop-vehiculo-condicion" author="codex">
        <preConditions onFail="MARK_RAN">
            <and>
                <tableExists tableName="vehiculo"/>
                <columnExists tableName="vehiculo" columnName="condicion"/>
            </and>
        </preConditions>
        <dropColumn tableName="vehiculo" columnName="condicion"/>
    </changeSet>

    <changeSet id="20260419143000-02-drop-vehiculo-anio-modelo" author="codex">
        <preConditions onFail="MARK_RAN">
            <and>
                <tableExists tableName="vehiculo"/>
                <columnExists tableName="vehiculo" columnName="anio_modelo"/>
            </and>
        </preConditions>
        <dropColumn tableName="vehiculo" columnName="anio_modelo"/>
    </changeSet>

</databaseChangeLog>
