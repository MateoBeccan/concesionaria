    <changeSet id="20260418150000-4-inventario-codigo-backfill" author="codex">
        <preConditions onFail="MARK_RAN">
            <and>
                <tableExists tableName="inventario"/>
                <columnExists tableName="inventario" columnName="codigo_interno_stock"/>
            </and>
        </preConditions>
        <sql>
            UPDATE inventario
            SET codigo_interno_stock = CONCAT('INV-', id)
            WHERE codigo_interno_stock IS NULL OR TRIM(codigo_interno_stock) = '';
        </sql>
    </changeSet>

    <changeSet id="20260418150000-5-inventario-codigo-unique" author="codex">
        <preConditions onFail="MARK_RAN">
            <and>
                <tableExists tableName="inventario"/>
                <columnExists tableName="inventario" columnName="codigo_interno_stock"/>
                <not>
                    <uniqueConstraintExists tableName="inventario" constraintName="ux_inventario__codigo_interno_stock"/>
                </not>
                <sqlCheck expectedResult="0">
                    SELECT COUNT(*) FROM (
                        SELECT codigo_interno_stock
                        FROM inventario
                        WHERE codigo_interno_stock IS NOT NULL AND TRIM(codigo_interno_stock) &lt;&gt; ''
                        GROUP BY codigo_interno_stock
                        HAVING COUNT(*) &gt; 1
                    ) t
                </sqlCheck>
            </and>
        </preConditions>
        <addUniqueConstraint tableName="inventario" columnNames="codigo_interno_stock" constraintName="ux_inventario__codigo_interno_stock"/>
    </changeSet>

