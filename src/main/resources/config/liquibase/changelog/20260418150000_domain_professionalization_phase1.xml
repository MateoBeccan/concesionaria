    <changeSet id="20260418150000-7-venta-importes-backfill" author="codex">
        <preConditions onFail="MARK_RAN">
            <tableExists tableName="venta"/>
        </preConditions>
        <sql>
            UPDATE venta SET total_pagado = 0 WHERE total_pagado IS NULL;
        </sql>
        <sql>
            UPDATE venta
            SET saldo = CASE
                WHEN total IS NULL THEN 0
                ELSE GREATEST(total - IFNULL(total_pagado, 0), 0)
            END
            WHERE saldo IS NULL;
        </sql>
    </changeSet>

    <changeSet id="20260418150000-8-venta-user-backfill" author="codex">
        <preConditions onFail="MARK_RAN">
            <and>
                <tableExists tableName="venta"/>
                <tableExists tableName="jhi_user"/>
                <columnExists tableName="venta" columnName="user_id"/>
            </and>
        </preConditions>
        <sql>
            UPDATE venta
            SET user_id = (SELECT MIN(id) FROM jhi_user)
            WHERE user_id IS NULL
              AND (SELECT MIN(id) FROM jhi_user) IS NOT NULL;
        </sql>
    </changeSet>

