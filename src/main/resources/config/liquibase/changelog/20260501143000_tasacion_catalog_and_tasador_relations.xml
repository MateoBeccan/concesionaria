<?xml version="1.0" encoding="utf-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="20260501143000-01-tasacion-version-id" author="codex">
        <preConditions onFail="MARK_RAN">
            <and>
                <tableExists tableName="tasacion_usado"/>
                <not>
                    <columnExists tableName="tasacion_usado" columnName="version_id"/>
                </not>
            </and>
        </preConditions>
        <addColumn tableName="tasacion_usado">
            <column name="version_id" type="bigint"/>
        </addColumn>
        <addForeignKeyConstraint
            baseTableName="tasacion_usado"
            baseColumnNames="version_id"
            referencedTableName="version"
            referencedColumnNames="id"
            constraintName="fk_tasacion_usado__version_id"/>
        <createIndex tableName="tasacion_usado" indexName="idx_tasacion_usado__version_id">
            <column name="version_id"/>
        </createIndex>
    </changeSet>

