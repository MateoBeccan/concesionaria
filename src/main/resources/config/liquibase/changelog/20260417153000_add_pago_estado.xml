<?xml version="1.0" encoding="utf-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="20260417153000-1" author="codex">
        <preConditions onFail="MARK_RAN">
            <not>
                <columnExists tableName="pago" columnName="estado"/>
            </not>
        </preConditions>
        <addColumn tableName="pago">
            <column name="estado" type="varchar(20)" defaultValue="REGISTRADO">
                <constraints nullable="false"/>
            </column>
        </addColumn>
        <update tableName="pago">
            <column name="estado" value="REGISTRADO"/>
            <where>estado IS NULL</where>
        </update>
    </changeSet>

</databaseChangeLog>
