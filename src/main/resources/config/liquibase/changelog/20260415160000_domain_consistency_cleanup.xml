    <changeSet id="20260415160000-7-drop-estado-venta-table" author="codex">
        <preConditions onFail="MARK_RAN">
            <tableExists tableName="estado_venta"/>
        </preConditions>
        <dropTable tableName="estado_venta"/>
    </changeSet>

    <changeSet id="20260415160000-8-keep-inventario-disponible-column" author="codex">
        <preConditions onFail="MARK_RAN">
            <and>
                <tableExists tableName="inventario"/>
                <columnExists tableName="inventario" columnName="disponible"/>
            </and>
        </preConditions>
        <sql>UPDATE inventario SET disponible = true WHERE disponible IS NULL;</sql>
        <addNotNullConstraint tableName="inventario" columnName="disponible" columnDataType="boolean"/>
    </changeSet>

    <changeSet id="20260415160000-9-create-inventario-historial" author="codex">
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="inventario_historial"/>
            </not>
        </preConditions>
        <createTable tableName="inventario_historial">
            <column name="id" type="bigint" autoIncrement="true">
                <constraints nullable="false" primaryKey="true"/>
            </column>
            <column name="fecha" type="${datetimeType}">
                <constraints nullable="false"/>
            </column>
            <column name="estado_anterior" type="varchar(255)"/>
            <column name="estado_nuevo" type="varchar(255)">
                <constraints nullable="false"/>
            </column>
            <column name="accion" type="varchar(100)">
                <constraints nullable="false"/>
            </column>
            <column name="detalle" type="varchar(500)"/>
            <column name="inventario_id" type="bigint">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addForeignKeyConstraint
            baseTableName="inventario_historial"
            baseColumnNames="inventario_id"
            constraintName="fk_inventario_historial__inventario_id"
            referencedTableName="inventario"
            referencedColumnNames="id"/>
    </changeSet>

    <changeSet id="20260415160000-10-unique-vehiculo-patente" author="codex">
        <preConditions onFail="MARK_RAN">
            <and>
                <tableExists tableName="vehiculo"/>
                <columnExists tableName="vehiculo" columnName="patente"/>
                <not>
                    <indexExists tableName="vehiculo" indexName="ux_vehiculo__patente"/>
                </not>
                <not>
                    <indexExists tableName="vehiculo" indexName="uk_vehiculo_patente"/>
                </not>
                <sqlCheck expectedResult="0">
                    SELECT COUNT(*) FROM (
                        SELECT index_name
                        FROM information_schema.statistics
                        WHERE table_schema = DATABASE()
                          AND table_name = 'vehiculo'
                          AND non_unique = 0
                        GROUP BY index_name
                        HAVING GROUP_CONCAT(column_name ORDER BY seq_in_index) = 'patente'
                    ) t
                </sqlCheck>
                <sqlCheck expectedResult="0">
                    SELECT COUNT(*) FROM (
                        SELECT patente
                        FROM vehiculo
                        WHERE patente IS NOT NULL AND TRIM(patente) &lt;&gt; ''
                        GROUP BY patente
                        HAVING COUNT(*) &gt; 1
                    ) t
                </sqlCheck>
            </and>
        </preConditions>
        <addUniqueConstraint tableName="vehiculo" columnNames="patente" constraintName="ux_vehiculo__patente"/>
    </changeSet>

