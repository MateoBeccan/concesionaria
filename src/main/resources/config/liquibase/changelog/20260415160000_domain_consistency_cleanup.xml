<?xml version="1.0" encoding="utf-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="20260415160000-1-add-venta-estado-column" author="codex">
        <preConditions onFail="MARK_RAN">
            <and>
                <tableExists tableName="venta"/>
                <not>
                    <columnExists tableName="venta" columnName="estado"/>
                </not>
            </and>
        </preConditions>
        <addColumn tableName="venta">
            <column name="estado" type="varchar(255)"/>
        </addColumn>
    </changeSet>

    <changeSet id="20260415160000-2-migrate-venta-estado" author="codex">
        <preConditions onFail="MARK_RAN">
            <and>
                <tableExists tableName="venta"/>
                <tableExists tableName="estado_venta"/>
                <columnExists tableName="venta" columnName="estado_venta_id"/>
                <columnExists tableName="venta" columnName="estado"/>
            </and>
        </preConditions>
        <sql>
            UPDATE venta v
            JOIN estado_venta ev ON ev.id = v.estado_venta_id
            SET v.estado = UPPER(TRIM(ev.codigo))
            WHERE v.estado IS NULL OR v.estado = '';
        </sql>
    </changeSet>

    <changeSet id="20260415160000-3-venta-estado-default" author="codex">
        <preConditions onFail="MARK_RAN">
            <and>
                <tableExists tableName="venta"/>
                <columnExists tableName="venta" columnName="estado"/>
            </and>
        </preConditions>
        <sql>UPDATE venta SET estado = 'PENDIENTE' WHERE estado IS NULL OR estado = '';</sql>
    </changeSet>

    <changeSet id="20260415160000-4-venta-estado-not-null" author="codex">
        <preConditions onFail="MARK_RAN">
            <and>
                <tableExists tableName="venta"/>
                <columnExists tableName="venta" columnName="estado"/>
            </and>
        </preConditions>
        <addNotNullConstraint tableName="venta" columnName="estado" columnDataType="varchar(255)"/>
    </changeSet>

    <changeSet id="20260415160000-5-drop-venta-estado-fk" author="codex">
        <preConditions onFail="MARK_RAN">
            <and>
                <tableExists tableName="venta"/>
                <foreignKeyConstraintExists foreignKeyName="fk_venta__estado_venta_id"/>
            </and>
        </preConditions>
        <dropForeignKeyConstraint baseTableName="venta" constraintName="fk_venta__estado_venta_id"/>
    </changeSet>

    <changeSet id="20260415160000-6-drop-venta-estado-id-column" author="codex">
        <preConditions onFail="MARK_RAN">
            <and>
                <tableExists tableName="venta"/>
                <columnExists tableName="venta" columnName="estado_venta_id"/>
            </and>
        </preConditions>
