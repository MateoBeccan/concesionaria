<?xml version="1.0" encoding="utf-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="20260412150000-1" author="codex" context="compatibility-data">
        <preConditions onFail="MARK_RAN">
            <tableExists tableName="version_motor"/>
            <sqlCheck expectedResult="0">select count(*) from version_motor</sqlCheck>
        </preConditions>

        <loadData
            file="config/liquibase/fake-data/version_motor.csv"
            separator=";"
            tableName="version_motor"
            usePreparedStatements="true">
            <column name="version_id" type="numeric"/>
            <column name="motor_id" type="numeric"/>
        </loadData>
    </changeSet>
</databaseChangeLog>
