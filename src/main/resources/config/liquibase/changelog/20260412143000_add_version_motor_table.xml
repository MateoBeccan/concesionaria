<?xml version="1.0" encoding="utf-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="20260412143000-1" author="codex">
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="version_motor"/>
            </not>
        </preConditions>

        <createTable tableName="version_motor">
            <column name="id" type="bigint" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="version_id" type="bigint">
                <constraints nullable="false"/>
            </column>
            <column name="motor_id" type="bigint">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addUniqueConstraint
            tableName="version_motor"
            columnNames="version_id,motor_id"
            constraintName="ux_version_motor_version_motor"
        />

        <addForeignKeyConstraint
            baseTableName="version_motor"
            baseColumnNames="version_id"
            constraintName="fk_version_motor__version_id"
            referencedTableName="version"
            referencedColumnNames="id"
        />

        <addForeignKeyConstraint
            baseTableName="version_motor"
            baseColumnNames="motor_id"
            constraintName="fk_version_motor__motor_id"
            referencedTableName="motor"
            referencedColumnNames="id"
        />
    </changeSet>
</databaseChangeLog>
