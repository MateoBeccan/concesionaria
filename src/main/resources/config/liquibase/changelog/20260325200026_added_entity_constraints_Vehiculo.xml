<?xml version="1.0" encoding="utf-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:ext="http://www.liquibase.org/xml/ns/dbchangelog-ext"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd
                        http://www.liquibase.org/xml/ns/dbchangelog-ext http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-ext.xsd">
    <!--
        Added the constraints for entity Vehiculo.
    -->
    <changeSet id="20260325200026-2" author="jhipster">

        <addForeignKeyConstraint baseColumnNames="version_id"
                                 baseTableName="vehiculo"
                                 constraintName="fk_vehiculo__version_id"
                                 referencedColumnNames="id"
                                 referencedTableName="version"
                                 />

        <addForeignKeyConstraint baseColumnNames="motor_id"
                                 baseTableName="vehiculo"
                                 constraintName="fk_vehiculo__motor_id"
                                 referencedColumnNames="id"
                                 referencedTableName="motor"
                                 />

        <addForeignKeyConstraint baseColumnNames="tipo_vehiculo_id"
                                 baseTableName="vehiculo"
                                 constraintName="fk_vehiculo__tipo_vehiculo_id"
                                 referencedColumnNames="id"
                                 referencedTableName="tipo_vehiculo"
                                 />
    </changeSet>
</databaseChangeLog>
