<?xml version="1.0" encoding="utf-8"?>
<databaseChangeLog
  xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                      http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

  <changeSet id="20260508013000-1" author="codex">
    <preConditions onFail="MARK_RAN">
      <tableExists tableName="movimiento_caja"/>
      <not>
        <indexExists tableName="movimiento_caja" indexName="ux_mov_caja_pago_tipo"/>
      </not>
    </preConditions>

    <createIndex tableName="movimiento_caja" indexName="ux_mov_caja_pago_tipo" unique="true">
      <column name="pago_id"/>
      <column name="tipo_movimiento"/>
    </createIndex>
  </changeSet>

</databaseChangeLog>
